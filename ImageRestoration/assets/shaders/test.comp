#version 450

layout (local_size_x = 16, local_size_y = 16) in;

layout (set = 0, binding = 0) uniform sampler2D inputSampler;
layout (set = 0, binding = 1, rgba8) uniform writeonly image2D outputImage;

void main() 
{
    // gl_GlobalInvocationID : 이미지 전체의 픽설 좌표를 나타냄
    ivec2 imageCoords = ivec2(gl_GlobalInvocationID.xy);
    
    // Get image dimensions 
    ivec2 imageDims = textureSize(inputSampler, 0);
    
    // Check if coordinates are within image bounds
    if (imageCoords.x >= imageDims.x || imageCoords.y >= imageDims.y) {
        return;
    }
    
    // Normalized coordinates for texture mapping
    vec2 uv = (vec2(imageCoords) + 0.5) / vec2(imageDims);
    vec4 color = texture(inputSampler, uv);

    // 3x3 Sharpening Filter Kernel
    // [ 0 -1  0 ]
    // [-1  5 -1 ]
    // [ 0 -1  0 ]
    
    // 딱 픽셀 한칸의 크기
    vec2 texelSize = 1.0 / vec2(imageDims);
    
    // 현재 픽셀(center)과 상하좌우 4개의 이웃 픽셀을 가져옵니다.
    // Convention 곱을 더 잘하기 위해 가운데는 명확하게 5를 곱하고, 
    // 상하좌우는 1씩 뺍니다.
    vec3 center = texture(inputSampler, uv).rgb;
    vec3 left   = texture(inputSampler, uv + vec2(-texelSize.x, 0.0)).rgb;
    vec3 right  = texture(inputSampler, uv + vec2(texelSize.x, 0.0)).rgb;
    vec3 up     = texture(inputSampler, uv + vec2(0.0, -texelSize.y)).rgb;
    vec3 down   = texture(inputSampler, uv + vec2(0.0, texelSize.y)).rgb;
    
    vec3 sharpened = center * 5.0 - (left + right + up + down);
    
    // Clamp to [0,1] range to avoid artifacts
    color.rgb = clamp(sharpened, 0.0, 1.0);

    imageStore(outputImage, imageCoords, color);
}